NEXT_PUBLIC_API_URL=http://localhost:58000/api/v1
# Mock 모드: true로 설정하면 서버 없이 mock 데이터로 동작 (Set to "true" to run with mock data, no server needed)
NEXT_PUBLIC_USE_MOCK=false
# (multi-tenant 비활성화 중 — 서버가 단일 organization 자동 매칭. 복원 시 재추가)
# NEXT_PUBLIC_COMPANY_CODE=ABC123
# 공개 가입 페이지 base URL — console 도메인이 console.* prefix를 가질 때 사용.
# 비워두면 window.location.origin 사용 (로컬 dev에선 그대로 둬도 됨).
# prod    Vercel: NEXT_PUBLIC_SIGNUP_BASE_URL=https://hermesops.site
# staging Vercel: NEXT_PUBLIC_SIGNUP_BASE_URL=https://stg.hermesops.site
NEXT_PUBLIC_SIGNUP_BASE_URL=
